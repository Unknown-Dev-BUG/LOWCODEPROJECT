# =========================================================================
# 👤 AUTHOR        : Tichakorn Khunyai (Unknown-Dev-BUG)
# 🏢 PROJECT       : LowcodeProject
# 📄 FILE          : .env.example
# ✍️ DESCRIPTION    : แม่แบบสำหรับกำหนดค่าตัวแปรสภาพแวดล้อม (Environment Variables)
#                     คัดลอกไฟล์นี้เป็น ".env" หรือ ".env.local" แล้วใส่ข้อมูลส่วนตัวของคุณ
# =========================================================================

# -------------------------------------------------------------------------
# 🤖 Gemini AI API Configuration
# -------------------------------------------------------------------------
# คีย์เชื่อมต่อกับ API ของ Google Gemini AI (ใช้สำหรับประมวลผลอ่านและถอดข้อมูลจากเอกสาร)
# สามารถขอรับคีย์ได้จาก Google AI Studio
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------------------------------------
# 🗄️ Supabase Configuration (Local Docker / Production)
# -------------------------------------------------------------------------
# ลิงก์เชื่อมต่อเข้าหลังบ้าน Supabase ของโปรเจกต์
# สำหรับเครื่อง Local พอร์ตเริ่มต้นคือ http://localhost:54300
VITE_SUPABASE_URL=http://localhost:54300

# คีย์สาธารณะสำหรับเชื่อมเข้าใช้งาน Client API ของ Supabase
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
